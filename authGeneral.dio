                <mxCell id="2" value="ユーザー情報処理" style="swimlane;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="40" width="240" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="&lt;ul style=&quot;padding-left: 20px; margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li&gt;email、passwordのみを保管&lt;/li&gt;&lt;li&gt;認証成功でuser_idとsunctumトークンをクライアントに返す&lt;/li&gt;&lt;li&gt;パスワード英数字８文字以上&lt;/li&gt;&lt;li&gt;レート制限&lt;/li&gt;&lt;li&gt;メールアドレスはクライアント単位でunique&lt;/li&gt;&lt;li&gt;X-client-id、X-client-codeを受け、クライアントの認証を成功したのちにユーザー認証を行う&lt;/li&gt;&lt;/ul&gt;" style="text;strokeColor=none;fillColor=none;html=1;whiteSpace=wrap;verticalAlign=middle;overflow=hidden;" parent="2" vertex="1">
                    <mxGeometry y="30" width="240" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="システム管理：クライアントログイン" style="swimlane;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="600" y="40" width="240" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="&lt;ul style=&quot;padding-left: 20px; margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li&gt;各クライアントごとに管理者アカウントを配給し、クライアントの持つユーザー情報のみを管理可能&lt;/li&gt;&lt;li&gt;ユーザー情報CRUD（テストデータ等）&lt;/li&gt;&lt;li&gt;他のアプリとのユーザーアカウント横断の選択&lt;/li&gt;&lt;li&gt;専用認証&lt;/li&gt;&lt;/ul&gt;" style="text;strokeColor=none;fillColor=none;html=1;whiteSpace=wrap;verticalAlign=middle;overflow=hidden;" parent="4" vertex="1">
                    <mxGeometry y="30" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="システム管理：ルートログイン" style="swimlane;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="320" y="40" width="240" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="&lt;ul style=&quot;padding-left: 20px; margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li&gt;ルートアカウントによってすべてのクライアントのデータを管理可能&lt;/li&gt;&lt;li&gt;クライアントが行える操作はすべて実行可能&lt;/li&gt;&lt;li&gt;専用認証&lt;/li&gt;&lt;li&gt;クライアントのCRUD&lt;/li&gt;&lt;li&gt;管理者クライアントの発行&lt;/li&gt;&lt;/ul&gt;" style="text;strokeColor=none;fillColor=none;html=1;whiteSpace=wrap;verticalAlign=middle;overflow=hidden;" parent="5" vertex="1">
                    <mxGeometry y="30" width="240" height="150" as="geometry"/>
